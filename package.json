{
  "name": "@stopreg/stopreg",
  "version": "1.0.3",
  "description": "The official Node.js SDK for StopReg.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "stopreg",
    "email",
    "verification",
    "fraud",
    "security"
  ],
  "author": "StopReg",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
